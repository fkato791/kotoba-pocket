{
  "expo": {
    "name": "Kotoba Pocket",
    "slug": "kotoba-pocket",
    "scheme": "kotobapocket",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "jp.example.kotobapocket",
      "usesAppleSignIn": true
    },
    "android": {
      "package": "jp.example.kotobapocket",
      "adaptiveIcon": {
        "backgroundColor": "#F8FAFC"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "replace-with-eas-project-id"
      }
    }
  }
}
